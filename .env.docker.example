# Copy this file to .env before running docker compose.
# Replace every secret before exposing the VPS to the internet.

WEB_PORT=3000
SUPABASE_API_PORT=8000
STUDIO_PORT=3001

# Public URLs from the browser. For local testing use http://localhost:8000 and http://localhost:3000.
# On Hostinger, use your VPS IP/domain, or proxy these behind HTTPS with Nginx/Caddy/Traefik.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=http://localhost:3000/auth/callback

# Generate fresh Supabase keys before running in a VPS.
JWT_SECRET=replace-with-jwt-secret-at-least-32-characters-long
SUPABASE_ANON_KEY=replace-with-anon-key-signed-with-JWT_SECRET
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-signed-with-JWT_SECRET

POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
SECRET_KEY_BASE=replace-with-a-long-random-secret-key-base-at-least-64-chars
REALTIME_DB_ENC_KEY=replace-with-16-char-key

JWT_EXPIRY=3600
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
DISABLE_SIGNUP=false

STUDIO_DEFAULT_ORGANIZATION=Directorio Negocios
STUDIO_DEFAULT_PROJECT=Local VPS
